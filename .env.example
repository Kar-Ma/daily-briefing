# Default location shown when the app first loads.
# You can change it in-app via the location pill — that override is stored
# in your browser. These are just the fallback values.
#
# Look up coordinates at https://www.latlong.net or any maps service.
LOCATION_LAT=51.9244
LOCATION_LON=4.4777
LOCATION_LABEL=Rotterdam

# Calendars to show in the Today section. Add as many as you want by
# incrementing the number (CALENDAR_1_*, CALENDAR_2_*, CALENDAR_3_*, …).
# The loop stops at the first missing _URL, so keep numbering sequential.
#
# Each URL is your calendar's "Secret address in iCal format" — find it in
# Google Calendar → that calendar's settings → Integrate calendar.
# These URLs are passwords. Anyone with one can read that calendar.
#
# Available colors: blue, green, purple, rose, amber, orange, cyan, fuchsia, teal, indigo.
CALENDAR_1_URL=
CALENDAR_1_NAME=Work
CALENDAR_1_COLOR=blue

CALENDAR_2_URL=
CALENDAR_2_NAME=Personal
CALENDAR_2_COLOR=orange

# === Optional / legacy ===
# GNews API key — earlier provider for headlines, kept for backwards compatibility.
# Not used once Brave Search + LLM curation is wired up. Safe to leave blank.
GNEWS_KEY=

# === API keys for news + LLM ===
# Brave Search API — used to fetch news articles before LLM curation.
# Get a free key at https://api.search.brave.com (2,000 queries/month free).
BRAVE_API_KEY=

# Anthropic API key for Claude models.
# Get one at https://console.anthropic.com (pay-per-use; minimum $5 to start).
ANTHROPIC_API_KEY=

# OpenAI API key for GPT models.
# Get one at https://platform.openai.com (pay-per-use; minimum $5 to start).
# Optional — only needed if you want to use GPT models for any task.
OPENAI_API_KEY=

# === LLM models ===
# Default model used when no task-specific model is set.
# Provider is auto-detected from the model name (claude-* → Anthropic, gpt-*/o* → OpenAI).
DEFAULT_LLM_MODEL=claude-haiku-4-5-20251001

# Per-task overrides — leave blank to use DEFAULT_LLM_MODEL.
# Mix providers freely (Claude for one, GPT for another).
NEWS_MODEL=
CLOTHING_MODEL=
