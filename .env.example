# Default location shown when the app first loads.
# You can change it in-app via the location pill — that override is stored
# in your browser. These are just the fallback values.
#
# Look up coordinates at https://www.latlong.net or any maps service.
LOCATION_LAT=51.9244
LOCATION_LON=4.4777
LOCATION_LABEL=Rotterdam

# Calendars to show in the Today section. Add as many as you want by
# incrementing the number (CALENDAR_1_*, CALENDAR_2_*, CALENDAR_3_*, …).
# The loop stops at the first missing _URL, so keep numbering sequential.
#
# Each URL is your calendar's "Secret address in iCal format" — find it in
# Google Calendar → that calendar's settings → Integrate calendar.
# These URLs are passwords. Anyone with one can read that calendar.
#
# Available colors: blue, green, purple, rose, amber, orange, cyan, fuchsia, teal, indigo.
CALENDAR_1_URL=
CALENDAR_1_NAME=Work
CALENDAR_1_COLOR=blue

CALENDAR_2_URL=
CALENDAR_2_NAME=Personal
CALENDAR_2_COLOR=orange
